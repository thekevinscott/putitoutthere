{
  "name": "putitoutthere",
  "version": "0.0.1",
  "description": "Polyglot release orchestrator for crates.io, PyPI, and npm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekevinscott/putitoutthere.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "putitoutthere": "./dist/cli-bin.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:action": "ncc build src/action.ts -o ../../dist-action --minify",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config tests/integration/vitest.integration.config.ts",
    "test:e2e": "pnpm build && vitest run --config tests/e2e/vitest.e2e.config.ts",
    "prepare": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.0.0",
    "@vercel/ncc": "^0.44.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "msw": "^2.15.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "yaml": "^2.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "dependencies": {
    "minimatch": "^10.2.5",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  }
}
