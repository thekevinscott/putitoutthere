{
  "name": "@putitoutthere/workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter putitoutthere run build",
    "build:action": "pnpm --filter putitoutthere run build:action",
    "build:ci": "pnpm --filter @putitoutthere/ci run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test:unit": "pnpm -r run test:unit",
    "test:unit:coverage": "pnpm --filter putitoutthere run test:unit:coverage",
    "test:integration": "pnpm --filter putitoutthere run test:integration",
    "test:e2e": "pnpm --filter putitoutthere run test:e2e"
  }
}
