{
  "name": "putitoutthere",
  "version": "0.0.1",
  "description": "Polyglot release orchestrator for crates.io, PyPI, and npm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekevinscott/put-it-out-there.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "putitoutthere": "./dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:action": "ncc build src/action.ts -o dist-action --minify",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "echo 'integration suite lands in tests/integration/ via #27' && exit 0",
    "test:e2e": "echo 'e2e suite lands in tests/e2e/ via #28' && exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^20.16.0",
    "@vercel/ncc": "^0.38.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "dependencies": {
    "minimatch": "^10.2.5",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  }
}
