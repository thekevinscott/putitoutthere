{
  "name": "putitoutthere",
  "version": "0.0.1",
  "description": "Polyglot release orchestrator for crates.io, PyPI, and npm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekevinscott/putitoutthere.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "putitoutthere": "./dist/cli-bin.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "MIGRATIONS.md",
    "docs/api",
    "docs/guide",
    "docs/getting-started.md",
    "docs/index.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:action": "ncc build src/action.ts -o dist-action --minify",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config test/integration/vitest.integration.config.ts",
    "test:e2e": "pnpm run build && vitest run --config test/e2e/vitest.e2e.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^10.2.1",
    "msw": "^2.13.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "dependencies": {
    "minimatch": "^10.2.5",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  }
}
